<!-- MainWindow.xaml -->
<Window x:Class="Assessment2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animal Microchip Management" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Customer Section -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Customers" FontSize="16" FontWeight="Bold" />
            <ListBox x:Name="lstCustomers" Height="200" Margin="0,5" />
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Add Customer" Width="100" Click="AddCustomer_Click" />
                <Button Content="Edit Customer" Width="100" Margin="5,0,0,0" Click="EditCustomer_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Animal Section -->
        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Animals" FontSize="16" FontWeight="Bold" />
            <ListBox x:Name="lstAnimals" Height="200" Margin="0,5" />
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Button Content="Add Animal" Width="100" Click="AddAnimal_Click" />
                <Button Content="Edit Animal" Width="100" Margin="5,0,0,0" Click="EditAnimal_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
