<Window x:Class="Assessment2.App.CustomerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Editor" Height="350" Width="400">
    <Window.Resources>
        <!-- Style to simulate PlaceholderText -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="Black" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="Text" Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Text" Value=""/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <StackPanel>
            <TextBox x:Name="firstName" Margin="0,5" Tag="First Name"/>
            <TextBox x:Name="surname" Margin="0,5" Tag="Surname"/>
            <TextBox x:Name="phoneNumber" Margin="0,5" Tag="Phone Number"/>
            <TextBox x:Name="address" Margin="0,5" Tag="Address"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Content="Save" Width="80" Margin="5,0" Click="OnSave"/>
                <Button Content="Cancel" Width="80" Margin="5,0" Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
