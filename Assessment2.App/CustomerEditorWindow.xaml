<Window x:Class="Assessment2.App.CustomerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Editor" Height="350" Width="400">
    <Grid Margin="10">
        <StackPanel>
            <TextBox x:Name="firstName" Margin="0,5" PlaceholderText="First Name"/>
            <TextBox x:Name="surname" Margin="0,5" PlaceholderText="Surname"/>
            <TextBox x:Name="phoneNumber" Margin="0,5" PlaceholderText="Phone Number"/>
            <TextBox x:Name="address" Margin="0,5" PlaceholderText="Address"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Content="Save" Width="80" Margin="5,0" Click="OnSave"/>
                <Button Content="Cancel" Width="80" Margin="5,0" Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
