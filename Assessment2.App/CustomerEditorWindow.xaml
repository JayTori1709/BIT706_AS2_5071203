<Window x:Class="Assessment2.App.CustomerEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Editor"
        Height="350"
        Width="400">
    <Window.Resources>
        <!-- Style to simulate PlaceholderText -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground"
                    Value="Black"/>
            <Style.Triggers>
                <Trigger Property="Text"
                        Value="">
                    <Setter Property="Foreground"
                            Value="Gray"/>
                    <Setter Property="Text"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=Tag}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused"
                        Value="True">
                    <Setter Property="Foreground"
                            Value="Black"/>
                    <Setter Property="Text"
                            Value=""/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <StackPanel>
            <TextBox Text="{Binding Customer.FirstName}"/>
            <TextBox Text="{Binding Customer.Surname}"/>
            <TextBox Text="{Binding Customer.PhoneNumber}"/>
            <TextBox Text="{Binding Customer.Address}"/>


            <StackPanel Orientation="Horizontal"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right">
                <Button Content="Save"
                        Width="80"
                        Margin="5,0"
                        Click="OnSave"/>
                <Button Content="Cancel"
                        Width="80"
                        Margin="5,0"
                        Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
