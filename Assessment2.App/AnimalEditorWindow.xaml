<Window x:Class="Assessment2.App.AnimalEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Path=Name, StringFormat=Edit Animal: \{0\}}"
        Height="300" Width="300">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Name:" />
            <TextBox Text="{Binding Name}" Margin="0,0,0,5" />

            <TextBlock Text="Type:" />
            <TextBox Text="{Binding Type}" Margin="0,0,0,5" />

            <TextBlock Text="Breed:" />
            <TextBox Text="{Binding Breed}" Margin="0,0,0,10" />

            <TextBlock Text="Owner ID:" />
            <TextBox Text="{Binding OwnerId}" Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Save" Width="80" Margin="5,0" Click="OnSave" IsDefault="True" />
                <Button Content="Cancel" Width="80" Margin="5,0" Click="OnCancel" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>