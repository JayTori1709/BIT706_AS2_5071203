<Window x:Class="Assessment2.App.SearchForCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search for Customer" Height="400" Width="500" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="searchBox"
                 Width="300"
                 Height="25"
                 Margin="0,0,0,10"
                 VerticalAlignment="Top"
                 TextChanged="SearchBox_TextChanged"
                 ToolTip="Search by name or phone..." />

        <ListBox x:Name="customerListBox"
                 Grid.Row="1"
                 DisplayMemberPath="FullName"
                 SelectionMode="Single" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Select" Width="80" Margin="5" Click="Select_Click"/>
            <Button Content="Cancel" Width="80" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
